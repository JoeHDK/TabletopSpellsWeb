# Copy this file to .env and fill in real values. Never commit .env.
#
# Generate strong secrets with:
#   openssl rand -base64 32
# Or on Windows PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { [byte](Get-Random -Max 256) }))

# PostgreSQL password
POSTGRES_PASSWORD=change_me_use_a_strong_random_password

# JWT signing key — must be at least 32 characters
JWT_KEY=change_me_use_openssl_rand_base64_32_output

# Chat encryption master key — must be at least 32 characters
CHAT_MASTER_KEY=change_me_use_openssl_rand_base64_32_output

# Caddy hostnames (comma-separated, no spaces)
# LAN:  SERVER_HOSTNAME=192.168.1.X,localhost
# VPS:  SERVER_HOSTNAME=yourdomain.com
SERVER_HOSTNAME=192.168.1.X,localhost
